[Unit]
Description=Siriusec Pagerduty Plugin
After=network.target

[Service]
Type=simple
Restart=on-failure
ExecStart=/usr/local/bin/siriusec-pagerduty start --config=/etc/siriusec-pagerduty.toml
ExecReload=/bin/kill -HUP $MAINPID
PIDFile=/run/siriusec-pagerduty.pid

[Install]
WantedBy=multi-user.target